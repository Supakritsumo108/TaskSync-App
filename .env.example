# === Gemini API Key สำหรับระบบ AI Chatbot ===
# สมัครรับ Key ได้ที่: https://aistudio.google.com/
VITE_GEMINI_API_KEY=ใส่_GEMINI_API_KEY_ของคุณที่นี่

# === Firebase Config สำหรับระบบ Login/Register ===
# ไปที่หน้า Firebase Console > Project Settings > General > เลื่อนลงมาที่หมวด Your apps
VITE_FIREBASE_API_KEY=ใส่_API_KEY_ที่นี่
VITE_FIREBASE_AUTH_DOMAIN=ใส่_AUTH_DOMAIN_ที่นี่
VITE_FIREBASE_PROJECT_ID=ใส่_PROJECT_ID_ที่นี่
VITE_FIREBASE_STORAGE_BUCKET=ใส่_STORAGE_BUCKET_ที่นี่
VITE_FIREBASE_MESSAGING_SENDER_ID=ใส่_SENDER_ID_ที่นี่
VITE_FIREBASE_APP_ID=ใส่_APP_ID_ที่นี่
